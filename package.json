{
  "name": "cc-backup",
  "version": "0.1.0",
  "description": "Snapshot Claude Code history and config into a timestamped backup directory",
  "keywords": [
    "backup",
    "claude",
    "claude-code",
    "cli"
  ],
  "license": "MIT",
  "author": "Dani Akash",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaniAkash/claude-code-backup.git"
  },
  "bin": {
    "cc-backup": "dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "fmt": "vp fmt --check",
    "fmt:fix": "vp fmt --write",
    "fallow": "fallow",
    "check": "concurrently --group --names lint,fmt,fallow --prefix-colors auto \"bun run lint\" \"bun run fmt\" \"bun run fallow\"",
    "test": "bun test --pass-with-no-tests",
    "ready": "bun run check && bun run test && bun run build",
    "prepublishOnly": "bun run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "fallow": "^2.96.0",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
